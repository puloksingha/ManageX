PORT=5000
MONGO_URI=DATABASE_CONNECTION_STRING
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
NODE_ENV=development

ACCESS_TOKEN_SECRET=GENERATE_SECRET_TOKEN
REFRESH_TOKEN_SECRET=GENERATE_SECRET_TOKEN
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

ADMIN_SECURITY_KEY=A_STRONG_SECURITY_KEY
ADMIN_EMAIL=ADMIN_EMAIL_ADDRESS
ADMIN_PASSWORD=A_STRONG_ADMIN_PASSWORD

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
MAIL_FROM=ManageX <your_email@example.com>
EMAIL_MOCK=true
ADMIN_NAME=System Admin
SEED_DEPARTMENTS=Computer Science,Electrical Engineering,Business Studies

FILE_STORAGE_PROVIDER=local
FILE_STORAGE_ROOT=managex
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
